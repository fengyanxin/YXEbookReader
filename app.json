{
  "pages": [
    "pages/index/index",
    "pages/upload/upload",
    "pages/reader/reader",
    "pages/settings/settings"
  ],
  "permission": {
    "scope.writePhotosAlbum": {
      "desc": "保存书籍封面到相册"
    }
  },
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#2c3e50",
    "navigationBarTitleText": "电子书阅读器",
    "navigationBarTextStyle": "white",
    "backgroundColor": "#f5f7fa",
    "enablePullDownRefresh": false
  },
  "tabBar": {
    "color": "#95a5a6",
    "selectedColor": "#3498db",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "书架",
        "iconPath": "images/bookshelf.png",
        "selectedIconPath": "images/bookshelf-active.png"
      },
      {
        "pagePath": "pages/upload/upload",
        "text": "上传",
        "iconPath": "images/upload.png",
        "selectedIconPath": "images/upload-active.png"
      },
      {
        "pagePath": "pages/settings/settings",
        "text": "设置",
        "iconPath": "images/settings.png",
        "selectedIconPath": "images/settings-active.png"
      }
    ],
    "custom": false,
    "safeAreaInsetBottom": true
  },
  "style": "v2",
  "sitemapLocation": "sitemap.json",
  "lazyCodeLoading": "requiredComponents",
  "useExtendedLib": {
    "kbone": false,
    "weui": false
  }
}
