/* pages/upload/upload.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
}

/* 状态栏占位 */
.status-bar-placeholder {
  width: 100%;
  height: var(--status-bar-height);
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
}

/* 头部样式 */
.header {
  padding: 30rpx 30rpx 20rpx;
  text-align: center;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #7f8c8d;
}

/* 上传区域 */
.upload-section {
  padding: 0 30rpx;
}

.upload-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

/* 上传区域 */
.upload-zone {
  border: 3rpx dashed #dee2e6;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  background: #f8f9fa;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.upload-zone.dragging {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.05);
}

.upload-zone:active {
  transform: scale(0.98);
}

.upload-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.upload-icon {
  font-size: 80rpx;
}

.upload-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 15rpx;
}

.upload-desc {
  display: block;
  font-size: 26rpx;
  color: #7f8c8d;
  margin-bottom: 10rpx;
}

.upload-hint {
  display: block;
  font-size: 22rpx;
  color: #95a5a6;
}

/* 上传进度 */
.upload-progress {
  margin-top: 30rpx;
}

.progress-bar {
  height: 8rpx;
  background: #e9ecef;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 15rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 600;
}

/* 格式说明 */
.format-info {
  margin-top: 40rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.format-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.format-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.format-detail {
  flex: 1;
}

.format-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 5rpx;
}

.format-desc {
  font-size: 22rpx;
  color: #7f8c8d;
}

/* 最近上传 */
.recent-section {
  padding: 40rpx 30rpx 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
}

.section-more {
  font-size: 26rpx;
  color: #667eea;
}

.recent-list {
  white-space: nowrap;
}

.recent-item {
  display: inline-block;
  width: 180rpx;
  margin-right: 20rpx;
  vertical-align: top;
}

.recent-cover {
  width: 180rpx;
  height: 240rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 15rpx;
}

.recent-cover-gradient {
  background-size: cover;
}

.recent-title {
  display: block;
  font-size: 24rpx;
  color: #2c3e50;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 云书库 */
.cloud-section {
  padding: 30rpx;
}

.cloud-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.cloud-icon {
  font-size: 60rpx;
  margin-right: 20rpx;
}

.cloud-info {
  flex: 1;
}

.cloud-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.cloud-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.cloud-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 底部提示 */
.footer-hint {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #95a5a6;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(10px);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 600rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  transition: transform 0.3s ease;
}

.modal.show .modal-content {
  transform: translate(-50%, -50%) scale(1);
}

.edit-modal {
  height: auto;
}

.modal-header {
  padding: 40rpx 30rpx 20rpx;
  text-align: center;
  border-bottom: 1rpx solid #ecf0f1;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2c3e50;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

/* 封面预览 */
.edit-cover-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.cover-image {
  width: 200rpx;
  height: 280rpx;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 20rpx;
}

.cover-image-gradient {
  background-size: cover;
}

.change-cover-btn {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
}

/* 表单样式 */
.edit-form {
  margin-top: 20rpx;
}

.form-item {
  margin-bottom: 25rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #7f8c8d;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid #ecf0f1;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #f8f9fa;
}

.form-input:focus {
  border-color: #667eea;
  background: #ffffff;
}

.form-textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid #ecf0f1;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #f8f9fa;
  min-height: 120rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #ecf0f1;
}

.modal-btn {
  flex: 1;
  border: none;
  border-radius: 0;
  padding: 30rpx;
  font-size: 30rpx;
}

.modal-btn:first-child {
  border-right: 1rpx solid #ecf0f1;
}
